rules_version = '2';

// =============================================================
// ⚠️ MODE DÉVELOPPEMENT — RÈGLES OUVERTES
// -------------------------------------------------------------
// L'authentification est désactivée côté client (voir
// AUTH_DESACTIVEE dans js/app.js). Pour que l'application
// puisse lire/écrire dans Firestore, ces règles autorisent
// temporairement TOUT accès à la collection « betail ».
//
// 🚨 NE PAS LAISSER EN PRODUCTION — n'importe qui peut lire
//    et modifier la base. À remplacer par les règles
//    sécurisées ci-dessous dès que l'authentification Google
//    sera réactivée.
// =============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /betail/{document} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// =============================================================
// 🔒 RÈGLES SÉCURISÉES À UTILISER UNE FOIS L'AUTH RÉACTIVÉE
// -------------------------------------------------------------
// Remplace le bloc ci-dessus par celui-ci, et modifie l'e-mail :
//
// service cloud.firestore {
//   match /databases/{database}/documents {
//     match /betail/{document} {
//       allow read, write: if request.auth != null
//         && request.auth.token.email == 'agriculteur@gmail.com';
//     }
//     match /{document=**} {
//       allow read, write: if false;
//     }
//   }
// }
// =============================================================
