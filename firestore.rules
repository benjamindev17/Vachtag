rules_version = '2';

// =============================================================
// Règles de sécurité Firestore — Vachtag
// -------------------------------------------------------------
// Seul un utilisateur authentifié dont l'e-mail correspond
// EXACTEMENT à l'adresse autorisée peut lire ou écrire dans
// la collection « betail ».
//
// ⚠️ MODIFIER l'adresse e-mail ci-dessous puis déployer ces
//    règles depuis la console Firebase :
//    Firestore Database → Règles → Coller → Publier
// =============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /betail/{document} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'agriculteur@gmail.com';
    }

    // Refus par défaut sur tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
